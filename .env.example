# Скопируйте в .env рядом с docker-compose.yml:
#   cp .env.example .env
#
# Обязательно смените POSTGRES_PASSWORD, SECRET_KEY и LIVEKIT_API_SECRET перед продакшеном.

# --- PostgreSQL ---
POSTGRES_DB=savetest_db
POSTGRES_USER=savetest_user
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Backend (критично) ---
SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe-32
DEBUG=False

# CORS: все origin, с которых открывают UI (через запятую).
# Локально:
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Стенд в LAN (раскомментируйте и подставьте IP ВМ):
# ALLOWED_ORIGINS=http://192.168.1.50:8080,http://localhost:8080
# Продакшен с доменом:
# ALLOWED_ORIGINS=https://app.example.com

UVICORN_WORKERS=4

# --- Проброс портов на хост (опционально) ---
# FRONTEND_PORT=8080
# BACKEND_PORT=8001
# ALLURE_SERVICE_PORT=3001
# MCP_SERVER_PORT=3002

# --- LiveKit (голос в CallBox) ---
# В docker-compose.production.yml LiveKit уже включён. Эти переменные подхватываются
# backend и контейнером livekit. Ключ и секрет должны совпадать у обоих сервисов.

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_in_production_please_32chars

# IP или hostname ВМ, с которого браузер реально заходит (не localhost с другого ПК).
# Compose подставит LIVEKIT_WS_URL=ws://<STAND_HOST>:7880, если LIVEKIT_WS_URL не задан.
STAND_HOST=192.168.1.50

# Явный WebSocket URL для клиентов (перекрывает ws://${STAND_HOST}:7880).
# Локально на той же машине:
# LIVEKIT_WS_URL=ws://localhost:7880
# LAN:
# LIVEKIT_WS_URL=ws://192.168.1.50:7880
# Продакшен за reverse proxy / отдельный поддомен:
# LIVEKIT_WS_URL=wss://calls.example.com:7880

# Публичный IP для ICE (куда клиент шлёт UDP-медиа). Только IP, не FQDN.
# • LAN: часто тот же STAND_HOST (private IP).
# • Интернет за NAT: WAN-адрес, на который проброшены TCP 7880/7881 и UDP 50000-50100.
# LIVEKIT_RTC_NODE_IP=192.168.1.50

# Принудительно use_external_ip в LiveKit (true/false). По умолчанию: true, если задан LIVEKIT_RTC_NODE_IP.
# LIVEKIT_RTC_USE_EXTERNAL_IP=true

# Порты LiveKit на хосте (если меняете проброс в compose):
# LIVEKIT_PORT=7880
# LIVEKIT_TCP_PORT=7881
# LIVEKIT_UDP_RANGE=50000-50100

# --- Заметки по LiveKit ---
# • Фаервол: откройте TCP 7880, 7881 и UDP 50000-50100 на хост с контейнером livekit.
# • Микрофон в Chrome на http://<LAN-IP> недоступен — нужен HTTPS у фронта или localhost.
# • Без голоса используйте docker-compose.production.no-livekit.yml вместо смены ключей.
